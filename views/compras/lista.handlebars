<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h1 class="mb-0"><i class="bi bi-cart"></i> Compras</h1>
    <p class="text-muted mb-0">Gestiona tus compras en cuotas</p>
  </div>
  <a href="/compras/nueva" class="btn btn-primary">
    <i class="bi bi-plus-circle"></i> Nueva Compra
  </a>
</div>

<!-- Resumen rápido -->
<div class="row mb-4">
  <div class="col-md-3">
    <div class="card bg-primary text-white">
      <div class="card-body text-center">
        <h5>Total Compras</h5>
        <h3 id="totalCompras">$0</h3>
        <small id="totalComprasUSD" class="opacity-75"></small>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card bg-warning text-white">
      <div class="card-body text-center">
        <h5>Pendientes</h5>
        <h3 id="comprasPendientes">0</h3>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card bg-success text-white">
      <div class="card-body text-center">
        <h5>Finalizadas</h5>
        <h3 id="comprasFinalizadas">0</h3>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card bg-info text-white">
      <div class="card-body text-center">
        <h5>Total</h5>
        <h3 id="totalItems">0</h3>
      </div>
    </div>
  </div>
</div>

<!-- Filtros como tabs -->
<ul class="nav nav-tabs mb-0" id="comprasTabs" role="tablist">
  <li class="nav-item" role="presentation">
    <button class="nav-link active" type="button" onclick="filtrarPorEstado('todas')">
      <i class="bi bi-list-ul"></i> Todas
      <span class="badge bg-secondary ms-1" id="badgeTodas">0</span>
    </button>
  </li>
  <li class="nav-item" role="presentation">
    <button class="nav-link" type="button" onclick="filtrarPorEstado('pendientes')">
      <i class="bi bi-clock"></i> Pendientes
      <span class="badge bg-warning ms-1" id="badgePendientes">0</span>
    </button>
  </li>
  <li class="nav-item" role="presentation">
    <button class="nav-link" type="button" onclick="filtrarPorEstado('finalizadas')">
      <i class="bi bi-check-circle"></i> Finalizadas
      <span class="badge bg-success ms-1" id="badgeFinalizadas">0</span>
    </button>
  </li>
</ul>

<!-- Lista de compras -->
<div class="card shadow-sm border-top-0" style="border-top-left-radius: 0; border-top-right-radius: 0;">
  <div class="card-body p-0">
    {{#if compras.length}}
      <div class="table-responsive">
        <table class="table table-hover mb-0" id="tablaCompras">
          <thead class="table-light">
            <tr>
              <th>Fecha</th>
              <th>Descripción</th>
              <th><i class="bi bi-tag"></i> Categoría</th>
              <th class="text-end">Monto</th>
              <th class="text-center">Cuotas</th>
              <th>Tarjeta</th>
              <th class="text-center">Estado</th>
              <th class="text-center">Acciones</th>
            </tr>
          </thead>
          <tbody>
            {{#each compras}}
              <tr class="compra-row"
                  data-fecha="{{this.fecha_compra}}"
                  data-monto="{{this.monto_total}}"
                  data-monto-usd="{{this.monto_total_usd}}"
                  data-cuotas="{{this.cantidad_cuotas}}"
                  data-cuotas-pagadas="{{this.cuotas_pagadas}}"
                  data-pendiente="{{this.pendiente_cuotas}}">
                <td>
                  <span class="text-muted small">{{formatDate this.fecha_compra}}</span>
                </td>
                <td>
                  <div class="fw-bold">{{this.descripcion}}</div>
                  <small class="text-muted">
                    {{formatMoney (div this.monto_total this.cantidad_cuotas)}}/cuota
                  </small>
                </td>
                <td>
                  <span class="badge bg-primary">{{this.categoria.nombre_categoria}}</span>
                </td>
                <td class="text-end">
                  <div class="fw-bold">
                    {{formatMoney this.monto_total}}
                  </div>
                  {{#if this.monto_total_usd}}
                    <small class="text-muted">US$ {{this.monto_total_usd}}</small>
                  {{/if}}
                </td>
                <td class="text-center" style="min-width: 140px;">
                  {{#if (gt this.cantidad_cuotas 1)}}
                    <!-- Progreso de cuotas -->
                    <div class="d-flex align-items-center gap-1">
                      <div class="progress flex-grow-1" style="height: 8px;" title="{{this.cuotas_pagadas}} de {{this.cantidad_cuotas}} cuotas pagadas">
                        {{#if (gt this.cuotas_pagadas 0)}}
                          <div class="progress-bar {{#if this.pendiente_cuotas}}bg-warning{{else}}bg-success{{/if}}"
                               style="width: {{round (mul (div this.cuotas_pagadas this.cantidad_cuotas) 100)}}%">
                          </div>
                        {{/if}}
                      </div>
                      <small class="text-muted text-nowrap">{{this.cuotas_pagadas}}/{{this.cantidad_cuotas}}</small>
                    </div>
                  {{else}}
                    <span class="badge bg-secondary">1 cuota</span>
                  {{/if}}
                </td>
                <td>
                  {{#if this.tarjeta}}
                    <small>{{this.tarjeta.nombre}}</small>
                  {{else}}
                    <small class="text-muted">-</small>
                  {{/if}}
                </td>
                <td class="text-center">
                  {{#if this.pendiente_cuotas}}
                    <span class="badge bg-warning text-dark">Pendiente</span>
                  {{else}}
                    <span class="badge bg-success">Finalizada</span>
                  {{/if}}
                </td>
                <td class="text-center">
                  <div class="btn-group btn-group-sm">
                    <a href="/compras/{{this.id}}" class="btn btn-outline-info" title="Ver detalle">
                      <i class="bi bi-eye"></i>
                    </a>
                    <a href="/compras/editar/{{this.id}}" class="btn btn-outline-warning" title="Editar">
                      <i class="bi bi-pencil"></i>
                    </a>
                    <form action="/compras/{{this.id}}?_method=DELETE" method="POST" class="d-inline">
                      <button type="submit" class="btn btn-outline-danger btn-sm"
                              onclick="return confirm('¿Estás seguro de eliminar esta compra?')"
                              title="Eliminar">
                        <i class="bi bi-trash"></i>
                      </button>
                    </form>
                  </div>
                </td>
              </tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    {{else}}
      <div class="text-center py-5">
        <i class="bi bi-cart text-muted" style="font-size: 4rem;"></i>
        <h5 class="mt-3">No hay compras registradas</h5>
        <p class="text-muted">Comienza agregando tu primera compra en cuotas</p>
        <a href="/compras/nueva" class="btn btn-primary">
          <i class="bi bi-plus-circle"></i> Crear primera compra
        </a>
      </div>
    {{/if}}
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  calcularResumenCompras();
});

function calcularResumenCompras() {
  const filas = document.querySelectorAll('.compra-row');
  let total = 0;
  let totalUSD = 0;
  let pendientes = 0;
  let finalizadas = 0;

  filas.forEach(fila => {
    const monto = parseFloat(fila.dataset.monto) || 0;
    const montoUSD = parseFloat(fila.dataset.montoUsd) || 0;
    const esPendiente = fila.dataset.pendiente === 'true';

    total += monto;
    totalUSD += montoUSD;

    if (esPendiente) {
      pendientes++;
    } else {
      finalizadas++;
    }
  });

  const cantidad = filas.length;

  document.getElementById('totalCompras').textContent = '$' + total.toLocaleString('es-AR');
  if (totalUSD > 0) {
    document.getElementById('totalComprasUSD').textContent = 'US$ ' + totalUSD.toLocaleString('es-AR', { minimumFractionDigits: 2 });
  }
  document.getElementById('comprasPendientes').textContent = pendientes.toString();
  document.getElementById('comprasFinalizadas').textContent = finalizadas.toString();
  document.getElementById('totalItems').textContent = cantidad.toString();

  // Update tab badges
  document.getElementById('badgeTodas').textContent = cantidad.toString();
  document.getElementById('badgePendientes').textContent = pendientes.toString();
  document.getElementById('badgeFinalizadas').textContent = finalizadas.toString();
}

function filtrarPorEstado(estado) {
  const filas = document.querySelectorAll('.compra-row');
  const tabs = document.querySelectorAll('#comprasTabs .nav-link');

  // Update active tab
  tabs.forEach((tab, index) => {
    tab.classList.remove('active');
    if ((estado === 'todas' && index === 0) ||
        (estado === 'pendientes' && index === 1) ||
        (estado === 'finalizadas' && index === 2)) {
      tab.classList.add('active');
    }
  });

  filas.forEach(fila => {
    const esPendiente = fila.dataset.pendiente === 'true';
    let mostrar = true;

    switch(estado) {
      case 'pendientes':
        mostrar = esPendiente;
        break;
      case 'finalizadas':
        mostrar = !esPendiente;
        break;
    }

    fila.style.display = mostrar ? '' : 'none';
  });
}
</script>
</content>
</invoke>